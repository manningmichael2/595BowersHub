# 595BowersHub Environment Variables
# Copy to .env and fill in real values (stored in Dashlane)
# NEVER commit .env to version control

# === Anthropic API ===
ANTHROPIC_API_KEY=sk-ant-...

# === PostgreSQL ===
DB_HOST=postgres
DB_PORT=5432
DB_NAME=finance
DB_USER=michael
DB_PASSWORD=CHANGE_ME

# === BowersHub AI ===
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
ADMIN_EMAIL=manningmichael2@gmail.com
ADMIN_PASSWORD=CHANGE_ME

# === Gmail (App Password) ===
GMAIL_IMAP_USER=manningmichael2@gmail.com
GMAIL_IMAP_PASSWORD=CHANGE_ME_16_CHAR

# === n8n ===
N8N_API_KEY=CHANGE_ME

# === File paths (host-side, for docker volume mounts) ===
