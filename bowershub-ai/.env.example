# BowersHub AI container environment variables
# Copy to .env on the server at ~/bowershub-ai/.env
# Real values stored in Dashlane

ANTHROPIC_API_KEY=sk-ant-...
DB_HOST=postgres
DB_PORT=5432
DB_NAME=finance
# Runtime DB role — least privilege (project-review.md C7). In prod this is the
# scoped `bowershub_app` role, NOT the cluster superuser.
DB_USER=bowershub_app
DB_PASSWORD=CHANGE_ME

# Elevated role used ONLY for the startup schema-migration connection (C1/C7).
# Schema DDL (ALTER/DROP on legacy objects, CREATE EXTENSION, triggers) needs
# privilege bowershub_app lacks; run_migrations() opens a short-lived connection
# as this role and closes it — request handling never uses it. Bootstrap this
# role once per cluster as the superuser — see docs/c7-db-roles-cutover.md.
# Leave BOTH blank to run migrations as DB_USER (correct for local/CI where
# DB_USER is already superuser, e.g. michael).
MIGRATION_DB_USER=bowershub_migrator
MIGRATION_DB_PASSWORD=CHANGE_ME

N8N_BASE=http://n8n:5678
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
FILES_ROOT=/files
KNOWLEDGE_ROOT=/knowledge
ADMIN_EMAIL=manningmichael2@gmail.com
ADMIN_PASSWORD=CHANGE_ME

# Gmail SMTP (for send-email skill) — App Password, not regular password
GMAIL_SMTP_USER=manningmichael2@gmail.com
GMAIL_SMTP_PASSWORD=CHANGE_ME_16_CHAR_APP_PASSWORD

# Gmail IMAP (for dashboard email widget) — same App Password
GMAIL_IMAP_USER=manningmichael2@gmail.com
GMAIL_IMAP_PASSWORD=CHANGE_ME_16_CHAR_APP_PASSWORD

# Pushover (push notifications to phone)
PUSHOVER_USER_KEY=CHANGE_ME
PUSHOVER_API_TOKEN=CHANGE_ME

# Ollama (local model for classification)
OLLAMA_URL=http://ollama:11434

# Filewriter (internal file/IMAP service)
FILEWRITER_URL=http://filewriter:5001

# CalDAV (Google Calendar — uses Gmail App Password for auth)
# CALDAV_URL is auto-constructed from CALDAV_USER if not set.
# CALDAV_PASSWORD defaults to GMAIL_SMTP_PASSWORD if not set separately.
# The App Password is the same 16-char one used for Gmail IMAP/SMTP — no new password needed.
CALDAV_URL=https://www.google.com/calendar/dav/manningmichael2@gmail.com/events/
CALDAV_USER=manningmichael2@gmail.com
CALDAV_PASSWORD=CHANGE_ME_SAME_APP_PASSWORD_AS_SMTP

# Public origin + CORS
# PUBLIC_URL is the deployed frontend origin (also used for password-reset links).
# It is automatically allowed by CORS. CORS_ORIGINS is an optional comma-separated
# list of *additional* allowed origins. Do NOT use "*" — the API sends credentials,
# which the browser rejects with a wildcard origin. Local dev origins
# (http://localhost:5173, http://127.0.0.1:5173) are always allowed.
PUBLIC_URL=https://bowershub.example.ts.net
# CORS_ORIGINS=https://other-frontend.example.com,http://192.168.1.50:5173
